  "keywords": ["prototype", "web-app", "react", "no-code", "figma", "vite", "deploy", "vercel"],
  "mcpServers": "./.mcp.json",
  "hooks": {
    "PermissionRequest": [{
      "matcher": "",
      "hooks": [{
        "type": "command",
